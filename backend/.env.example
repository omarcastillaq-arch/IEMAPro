# ─── Horizon Medical WSS - Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ─── Node.js ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── JWT Authentication ──────────────────────────────────────────────────────
# REQUIRED: Secret key for signing/verifying JWT tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING

# JWT signing algorithm (default: HS256)
JWT_ALGORITHM=HS256

# Maximum token age (default: 24h). Tokens older than this are rejected.
JWT_MAX_AGE=24h

# Set to 'false' to disable authentication (ONLY for development/testing)
AUTH_ENABLED=true

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_MONGO_ROOT_PASSWORD
MONGO_USER=hrzmed_user
MONGO_PASSWORD=CHANGE_ME_MONGO_USER_PASSWORD
DBNAME=hrzsignaldb
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongo:27017/${DBNAME}?authSource=${DBNAME}

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Maximum concurrent WebSocket connections per IP address
MAX_CONNECTIONS_PER_IP=10

# Maximum messages per second per WebSocket connection
MAX_MESSAGES_PER_SECOND=50

# Auth failures before temporary IP ban
MAX_AUTH_FAILURES_PER_IP=5

# Ban duration in milliseconds (default: 15 minutes)
BAN_DURATION_MS=900000



# ─── Redis Cache (Phase 12) ─────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=hrzmed:
REDIS_TTL_SESSION=300
REDIS_TTL_DEVICE=60
REDIS_TTL_QUERY=30
REDIS_TTL_STATS=15

# ─── MongoDB Pool (Phase 12) ────────────────────────────────────────────
MONGO_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
MONGO_CONNECT_TIMEOUT=10000
MONGO_SOCKET_TIMEOUT=45000

# ─── WebSocket Performance (Phase 12) ───────────────────────────────────
# Enable permessage-deflate compression (40-70% bandwidth reduction)
WS_COMPRESSION_ENABLED=true
# Ping interval for stale connection detection (ms)
WS_PING_INTERVAL=30000
# Max buffered amount before dropping messages (backpressure)
WS_MAX_BACKPRESSURE=65536
# Batched broadcast interval (ms, 0 = immediate)
WS_BATCH_INTERVAL=50
# Max WebSocket payload size (bytes)
WS_MAX_PAYLOAD=1048576

# ─── Cluster Mode (Phase 12) ────────────────────────────────────────────
# Enable multi-process clustering for horizontal scaling
CLUSTER_ENABLED=false
# Number of worker processes (0 = auto, based on CPU cores)
CLUSTER_WORKERS=0
